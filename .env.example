# ╔══════════════════════════════════════════════════════════════╗
# ║  NEXUS SPECTER PRO — Environment Configuration              ║
# ║  Copy to .env and fill in your API keys                     ║
# ║  NEVER commit .env to version control                       ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Specter AI ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NSP_AI_MODEL=claude-opus-4-5

# ─── OSINT APIs ──────────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here
HUNTER_API_KEY=your_hunter_api_key_here
HIBP_API_KEY=your_hibp_api_key_here
FOFA_EMAIL=your_fofa_email_here
FOFA_KEY=your_fofa_key_here
ZOOMEYE_API_KEY=your_zoomeye_api_key_here

# ─── Vulnerability Scanners ──────────────────────────────────────
NESSUS_URL=https://localhost:8834
NESSUS_ACCESS_KEY=your_nessus_access_key
NESSUS_SECRET_KEY=your_nessus_secret_key
OPENVAS_HOST=localhost
OPENVAS_PORT=9390
OPENVAS_USER=admin
OPENVAS_PASS=your_openvas_password

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://nsp:nsp_password@localhost:5432/nexus_specter
REDIS_URL=redis://localhost:6379/0

# ─── Dashboard ───────────────────────────────────────────────────
NSP_SECRET_KEY=change_this_to_a_random_secret_key_64_chars
NSP_DASHBOARD_PORT=8080
NSP_DASHBOARD_HOST=0.0.0.0

# ─── C2 Integration ──────────────────────────────────────────────
SLIVER_HOST=localhost
SLIVER_PORT=31337
SLIVER_TOKEN=your_sliver_token
COBALT_STRIKE_HOST=localhost
COBALT_STRIKE_PORT=50050
COBALT_STRIKE_PASS=your_cs_password

# ─── Notifications ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASS=your_smtp_password
ALERT_EMAIL=contact@optimiumnexus.com
